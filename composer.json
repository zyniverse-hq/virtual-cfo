{
    "name": "zysk/virtual-cfo",
    "type": "project",
    "description": "Virtual CFO - Automated bank statement processing and Tally integration",
    "keywords": ["laravel", "filament", "accounting", "tally"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "barryvdh/laravel-dompdf": "^3.1",
        "filament/filament": "~5.0",
        "laravel/ai": "^0.1",
        "laravel/framework": "^12.0",
        "laravel/nightwatch": "^1.28",
        "laravel/tinker": "^2.10",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-activitylog": "^4.11",
        "symfony/http-client": "^8.0",
        "symfony/mailgun-mailer": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-laravel": "^4",
        "pestphp/pest-plugin-livewire": "^4",
        "pestphp/pest-plugin-type-coverage": "^4",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
